# =========================================================
# Laravel Root .htaccess (shared hosting safe version)
# =========================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1️⃣ Force HTTPS
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

    # 1.5️⃣ Route the bare site root ("/") into Laravel.
    #    The document root is itself a directory, so the "!-d" guard on rules
    #    #2 and #3 below is FALSE for the root request — those rules skip it,
    #    the "/" never reaches public/index.php, and Apache falls back to a
    #    directory index. There is no index file at the project root (it lives
    #    in /public), and with "Options -Indexes" set that surfaces as a
    #    403 Forbidden on the homepage even though /auth/login and every other
    #    path work fine. This explicit rule handles only the empty path.
    RewriteRule ^$ public/index.php [L]

    # 2️⃣ Serve any request that matches a REAL FILE inside /public directly.
    #    Replaces a hardcoded css|js|img|fonts|vendor whitelist, which silently
    #    404'd anything outside those 5 names — e.g. KuBo's uploaded images
    #    under public/file/kubo/... never matched it and fell through to rule
    #    #3 below, which routed them into Laravel's router. Laravel has no
    #    route for /file/..., so it 404'd there too, even though the file
    #    existed on disk the whole time.
    #    SECURITY NOTE: this can only ever serve files that already live
    #    inside /public — the exact same boundary Laravel's own convention
    #    relies on for "what's safe to expose publicly." It cannot reach
    #    .env, app/, routes/, database/, the top-level vendor/, or storage/
    #    logs, since all of those sit OUTSIDE /public and this check is
    #    hard-scoped to %{DOCUMENT_ROOT}/public. Dotfiles stay blocked by the
    #    <FilesMatch "^\."> rule below regardless of this rule. .php files
    #    inside /public (like index.php) still get executed by PHP, not
    #    dumped as source — that's Apache's separate PHP handler, unrelated
    #    to mod_rewrite, exactly as already happens via rule #3 today.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L]

    # 3️⃣ Redirect all other requests to public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>

# Disable directory listing
Options -Indexes

# Hide dot files (.env, .git, etc.)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
